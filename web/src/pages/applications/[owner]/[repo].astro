---
import Layout from '~/layouts/Layout.astro';
import TagChip from '~/components/TagChip.astro';
import { fetchApprovedApplications } from '~/lib/applications';
import { ownerRepo } from '~/lib/packages';
import type { ApplicationRecord } from '~/lib/pb';

export async function getStaticPaths() {
  const all = await fetchApprovedApplications();
  return all.map((a) => {
    const { owner, repo } = ownerRepo(a.name);
    return {
      params: { owner, repo },
      props: { app: a },
    };
  });
}

interface Props {
  app: ApplicationRecord;
}

const { app } = Astro.props;
const submitterName = app.expand?.submitter?.name || app.expand?.submitter?.id || 'unknown';
const pushed = app.pushed_at
  ? new Date(app.pushed_at).toLocaleDateString(undefined, {
      year: 'numeric',
      month: 'short',
      day: 'numeric',
    })
  : null;

const usePrompt = `- deploy ${app.name}
- the docker image is ${app.docker_image}
- the host is WWW.REPLACE_ME.COM
- DO NOT USE no-infra
- use a .env file
- create only public tasks in bb.edn
- create distinct ssh keys
- tell me how to create and how to delete
- run BB_EDN_REPO=bigconfig-ai/once npx @bigconfig/bb validate and iterate on failures`;
---

<Layout title={`${app.name} — BigConfig Marketplace`} description={app.description}>
  <section class="mx-auto max-w-6xl px-6 pt-20 pb-12">
    <a
      href="/applications"
      class="text-sm text-neutral-400 hover:text-yellow-400">← All applications</a
    >
    <div class="mt-6 flex flex-wrap items-start justify-between gap-6">
      <div>
        <h1
          class="text-4xl font-semibold tracking-tight text-white md:text-5xl"
        >
          {app.name}
        </h1>
        <p class="mt-2 text-sm text-neutral-500">added by {submitterName}</p>
        {
          app.tags && app.tags.length > 0 && (
            <div class="mt-4 flex flex-wrap gap-2">
              {app.tags.map((t) => (
                <TagChip tag={t} />
              ))}
            </div>
          )
        }
      </div>
      <a
        href={app.github_url}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-yellow-400 px-6 py-3 text-sm font-semibold text-neutral-950 transition hover:bg-yellow-300"
        >View on GitHub →</a
      >
    </div>
  </section>

  <section class="mx-auto max-w-6xl px-6 pb-24">
    <div class="grid gap-8 md:grid-cols-3">
      <div class="md:col-span-2">
        <div
          class="rounded-2xl border border-neutral-800 bg-neutral-900/40 p-8"
        >
          <h2 class="text-lg font-semibold text-white">About</h2>
          <p class="mt-3 leading-relaxed text-neutral-300">
            {app.description || 'No description provided.'}
          </p>
        </div>
        <div
          class="mt-6 rounded-2xl border border-neutral-800 bg-neutral-900/40 p-8"
        >
          <div class="flex items-center justify-between gap-4">
            <h2 class="text-lg font-semibold text-white">Use it</h2>
            <button
              id="copy-use-prompt"
              type="button"
              data-prompt={usePrompt}
              class="rounded-full border border-neutral-700 px-3 py-1 text-xs font-semibold text-neutral-200 hover:border-yellow-400 hover:text-yellow-400"
            >Copy prompt</button>
          </div>
          <p class="mt-3 text-sm text-neutral-400">
            Give this prompt to your agent to deploy the image with the Once
            BigConfig Package.
          </p>
          <pre
            class="mt-4 whitespace-pre-wrap rounded-lg border border-neutral-800 bg-neutral-950 p-3 text-xs leading-relaxed text-neutral-300"><code>{usePrompt}</code></pre>
          <p class="mt-4 text-sm text-neutral-400">
            The prompt follows the documented <a href="/documentation#once-package" class="text-yellow-400 hover:underline">Once BigConfig Package</a> flow.
          </p>
        </div>
        {
          app.og_image && (
            <div class="mt-6 overflow-hidden rounded-2xl border border-neutral-800">
              <img
                src={app.og_image}
                alt={`${app.name} preview`}
                class="w-full"
                loading="lazy"
              />
            </div>
          )
        }
      </div>
      <aside class="space-y-4">
        <div class="rounded-2xl border border-neutral-800 bg-neutral-900/40 p-6">
          <div class="text-xs font-semibold tracking-widest text-neutral-500 uppercase">
            Repository
          </div>
          <dl class="mt-3 space-y-3 text-sm">
            <div class="flex justify-between gap-4">
              <dt class="text-neutral-400">Stars</dt>
              <dd class="text-white">{app.stars}</dd>
            </div>
            {
              app.default_branch && (
                <div class="flex justify-between gap-4">
                  <dt class="text-neutral-400">Branch</dt>
                  <dd class="text-white font-mono text-xs">
                    {app.default_branch}
                  </dd>
                </div>
              )
            }
            {
              pushed && (
                <div class="flex justify-between gap-4">
                  <dt class="text-neutral-400">Last push</dt>
                  <dd class="text-white">{pushed}</dd>
                </div>
              )
            }
          </dl>
        </div>
        <div class="rounded-2xl border border-neutral-800 bg-neutral-900/40 p-6">
          <div class="text-xs font-semibold tracking-widest text-neutral-500 uppercase">
            ONCE contract
          </div>
          <ul class="mt-3 space-y-2 text-sm text-neutral-300">
            <li>HTTP on :80</li>
            <li>Healthcheck at /up</li>
            <li>Persistent data in /storage</li>
          </ul>
        </div>
      </aside>
    </div>
  </section>
</Layout>

<script>
  const btn = document.getElementById('copy-use-prompt') as HTMLButtonElement | null;
  btn?.addEventListener('click', async () => {
    const prompt = btn.dataset.prompt ?? '';
    try {
      await navigator.clipboard.writeText(prompt);
      const prev = btn.textContent;
      btn.textContent = 'Copied';
      setTimeout(() => (btn.textContent = prev), 1200);
    } catch {}
  });
</script>
